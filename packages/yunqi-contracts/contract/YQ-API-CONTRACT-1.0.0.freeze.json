      "required": [
        "dateTime"
      ],
      "type": "object"
    },
    "CalculationSuccessResponse": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "enum": [
            "SUCCESS"
          ],
          "type": "string"
        },
        "data": {
          "$ref": "#/components/schemas/YunQiCalculationDto"
        },
        "message": {
          "enum": [
            ""
          ],
          "type": "string"
        }
      },
      "required": [
        "code",
        "data",
        "message"
      ],
      "type": "object"
    },
    "ErrorResponse": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "anyOf": [
            {
              "enum": [
                "INVALID_ARGUMENT"
              ],
              "type": "string"
            },
            {
              "enum": [
                "CALENDAR_PROVIDER_UNAVAILABLE"
              ],
              "type": "string"
            },
            {
              "enum": [
                "INTERNAL_ERROR"
              ],
              "type": "string"
            }
          ]
        },
        "details": {
          "additionalProperties": {},
          "type": "object"
        },
        "message": {
          "type": "string"
        }
      },
      "required": [
        "code",
        "details",
        "message"
      ],
      "type": "object"
