              "enum": [
                "DIFFERENT_QI"
              ],
              "type": "string"
            }
          ]
        },
        "traditionalLabel": {
          "type": "string"
        }
      },
      "required": [
        "direction",
        "elementRelation",
        "qiRelation",
        "traditionalLabel"
      ],
      "type": "object"
