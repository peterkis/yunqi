    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "tyme4ts": "1.5.2"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.10",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
